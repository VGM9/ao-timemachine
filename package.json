{
  "name": "@vgm9/ao-timemachine",
  "version": "1.0.0",
  "description": "Avatar Of Time Machine — agentic SME zone for Mac Time Machine backup setup across all destination types",
  "keywords": ["time-machine", "macos", "backup", "smb", "sparsebundle", "agent", "ao"],
  "license": "MIT",
  "bin": {
    "ao-tm": "./bin/ao-tm.js"
  },
  "scripts": {
    "inspect":              "bash scripts/mac/check-hardware.sh",

    "backup:configure":     "node bin/ao-tm.js setup",
    "backup:status":        "bash scripts/mac/status.sh",
    "backup:start":         "sudo tmutil startbackup && tmutil status",
    "backup:diagnose":      "node bin/ao-tm.js diagnose",

    "sparsebundle:create":  "bash scripts/mac/create-sparsebundle.sh",
    "automount:install":    "bash scripts/mac/install-launchagent.sh",

    "windows:drives":       "powershell -ExecutionPolicy Bypass -File scripts/windows/check-drives.ps1",
    "windows:share":        "powershell -ExecutionPolicy Bypass -File scripts/windows/create-share.ps1",
    "windows:samba":        "bash scripts/windows/wsl-samba-setup.sh"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vgm9/ao-timemachine.git"
  },
  "homepage": "https://github.com/vgm9/ao-timemachine#readme",
  "bugs": {
    "url": "https://github.com/vgm9/ao-timemachine/issues"
  }
}
